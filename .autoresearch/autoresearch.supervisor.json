{
  "interval_seconds": 3600,
  "max_cycles": null,
  "session_id": "continuous",
  "base_branch": "main",
  "branch_prefix": "autoresearch",
  "worktree_root": ".autoresearch/worktrees",
  "git_binary": "/Users/rau/bin/codex-git-proxy",
  "agent_command": "/Applications/Codex.app/Contents/Resources/codex exec --full-auto --cd . -",
  "review_command": "/Applications/Codex.app/Contents/Resources/codex exec review --uncommitted --full-auto --output-last-message .autoresearch/review.md",
  "post_merge_command": "bash .autoresearch/autoresearch.checks.sh",
  "auto_merge": true,
  "push": true,
  "git_user_name": "omerlefaruk",
  "git_user_email": "23411283+omerlefaruk@users.noreply.github.com",
  "memory_url": "http://127.0.0.1:37777",
  "memory_required": false,
  "min_confidence": null,
  "max_artifact_bytes": 536870912,
  "max_recent_rejections": 3,
  "improvement_scouts": {
    "enabled": true,
    "max_parallel": 3,
    "agents": [
      {
        "name": "code_explorer",
        "focus": "Search allowed source and docs paths for small reliability, maintainability, or evidence-quality improvements.",
        "paths": ["tools/", "harness/memory/", "harness/reporting/", "harness/rpa/", "harness/ai/", "docs/", ".autoresearch/"],
        "model": "gpt-5.4-mini",
        "reasoning_effort": "medium",
        "timeout_seconds": 180
      },
      {
        "name": "failure_analyst",
        "focus": "Inspect recent failure reports, autoresearch audit entries, and memory-facing code for recurring failure classes.",
        "paths": ["runs/", ".autoresearch/", "harness/memory/", "tests/"],
        "model": "gpt-5.4-mini",
        "reasoning_effort": "medium",
        "timeout_seconds": 180
      },
      {
        "name": "test_gap_planner",
        "focus": "Look for narrow missing tests around existing autoresearch, memory, reporting, RPA, or AI helper behavior.",
        "paths": ["tests/", "tools/", "harness/memory/", "harness/reporting/", "harness/rpa/", "harness/ai/"],
        "model": "gpt-5.4-mini",
        "reasoning_effort": "medium",
        "timeout_seconds": 180
      }
    ]
  },
  "allowed_paths": [
    "tools/",
    "tests/",
    "docs/",
    "harness/memory/",
    "harness/reporting/",
    "harness/rpa/",
    "harness/ai/",
    ".agents/config/",
    ".autoresearch/"
  ]
}
